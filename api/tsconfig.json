{
    "compilerOptions": {
        "strict": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "module": "nodenext",
        "target": "es2022",
        "moduleResolution": "nodenext",
        "sourceMap": true,
        "outDir": "dist",
        "types": ["node"]
    },
    "exclude": [],
    "include": [
        "index.ts",
        "routes/**/*",
        "lib/**/*"
    ]
}
